# Kopiér denne fil til .env og udfyld dine egne værdier.

# Sti til OCES3-certifikat (.cer, DER-format)
# Anbefalet placering: offline uden for projektmappen, f.eks. ~/.credentials/
CERT_FILE=/sti/til/dit/certifikat.cer

# Sti til tilhørende privat nøgle (.key eller .pem, ukrypteret PKCS8)
# Anbefalet placering: offline uden for projektmappen, f.eks. ~/.credentials/
KEY_FILE=/sti/til/din/private.key

# Udbydersystem-ID som er registreret hos STIL
UDBYDER_SYSTEM_ID=ABxxxxxx

# Standard-institutionsliste (kommasepareret)
# Bruges når ingen instnr angives på kommandolinjen.
# Kan udelades hvis man altid angiver instnr direkte.
INSTITUTIONS=101088,101155,101126

# Logniveau: DEBUG, INFO, WARNING eller ERROR (standard: INFO)
LOG_LEVEL=INFO

# Valgfri logfil — udelad for kun at logge til konsollen
# LOG_FILE=wsieksport.log
